{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with goals and streak data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "dailyGoal": { "type": "number", "description": "Daily study goal in hours" },
        "weeklyGoal": { "type": "number", "description": "Weekly study goal in hours" },
        "monthlyGoal": { "type": "number", "description": "Monthly study goal in hours" },
        "currentStreak": { "type": "integer" },
        "longestStreak": { "type": "integer" },
        "lastStudyDate": { "type": "string", "format": "date" },
        "examDate": { "type": "string", "format": "date-time" },
        "examTitle": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Schedule": {
      "title": "ScheduleItem",
      "description": "Weekly schedule planned item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "day": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"] },
        "subject": { "type": "string" },
        "plannedHours": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["day", "subject", "plannedHours"]
    },
    "Session": {
      "title": "StudySession",
      "description": "Completed study session log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "subject": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "duration", "subject"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile, streaks, and goals"
    },
    "/users/{userId}/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Weekly scheduled study slots for this user"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Study logs for sessions completed by this user"
    }
  }
}
